{
  "manifest_version": 3,
  "name": "Gmail AI Reply",
  "version": "1.0",
  "description": "Generate AI replies in Gmail",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://mail.google.com/*", "http://localhost:5051/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}